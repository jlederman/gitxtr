root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# GitHub Actions / YAML keep the conventional 2-space style.
[*.{yml,yaml}]
indent_size = 2

# Make requires real tabs for recipe lines.
[Makefile]
indent_style = tab
